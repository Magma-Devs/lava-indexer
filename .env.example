# DB creds used by both postgres and indexer containers.
# Pick a strong DB_PASSWORD before bringing up compose — it's required
# (compose will fail fast with no fallback). The same password is what
# the bridge-network pg_hba enforces via scram-sha-256.
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=postgres

# Compose project name: drives container prefixes + default volume names.
# Let two stacks coexist on one host by picking distinct names, e.g.
# `lava-mainnet` and `lava-testnet`.
PROJECT_NAME=lava-indexer

# Named volume holding the Postgres data directory. Typically
# `${PROJECT_NAME}_postgres_data`; overriding here lets an existing volume
# be re-attached across folder/project renames.
DATA_VOLUME=lava-indexer_postgres_data

# Host-side ports. Change per-stack when running multiple instances.
INDEXER_PORT=8080
GRAPHQL_PORT=3000
POSTGRES_PORT=5432

# Optional: override the single RPC endpoint via env (config.yml endpoints:
# list takes precedence when present).
LAVA_RPC_ENDPOINT=https://lava.tendermintrpc.lava.build:443
